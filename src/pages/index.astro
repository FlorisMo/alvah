---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = await getCollection('milestones');
const oefeningen = await getCollection('oefeningen');
const vragen = await getCollection('vragen');

const laatsteMilestone = milestones
  .slice()
  .sort((a, b) => b.data.datum.getTime() - a.data.datum.getTime())[0];

const actieveInterventies = oefeningen.filter(
  (o) => o.data.evidence === 'sterk' || o.data.evidence === 'matig',
).length;

const openVragen = vragen.filter(
  (v) => v.data.status === 'open' || v.data.status === 'in-gesprek',
).length;

const formatDatum = (d: Date) =>
  d.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });

const navCards = [
  { num: '01', titel: 'Samenvatting', pad: '/samenvatting', desc: 'Het verhaal in één pagina, voor wie net aansluit' },
  { num: '02', titel: 'Dossier', pad: '/dossier', desc: 'Uitgebreid onderzoeksrapport met wetenschappelijke onderbouwing' },
  { num: '03', titel: 'Resultaten', pad: '/resultaten', desc: 'Cito, Pluspunt en onderwijsbehoeften SWV' },
  { num: '04', titel: 'Wetenschap', pad: '/wetenschap', desc: 'PKU, dyslexie en executieve functies met bronverwijzing' },
  { num: '05', titel: 'Onderwijs', pad: '/onderwijs', desc: 'Nederlandse schoolprocessen, rechten, escalatie' },
  { num: '06', titel: 'Doubleren', pad: '/doubleren', desc: 'Wetenschap en beslismatrix bij overweging verlengde bouw' },
  { num: '07', titel: 'Oefeningen', pad: '/oefeningen', desc: 'Filterbare catalogus van interventies en tools' },
  { num: '08', titel: 'Voortgang', pad: '/voortgang', desc: 'Tijdlijn met milestones en lopend onderzoek' },
  { num: '09', titel: 'Vragen', pad: '/vragen', desc: 'Openstaande vragen voor ons, school en met Alvah' },
  { num: '10', titel: 'Bronnen', pad: '/bronnen', desc: 'Alle geraadpleegde literatuur en verwijzingen' },
];
---
<BaseLayout
  title="Alvah, dossier"
  description="Werkdocument voor wie met Alvah werkt: thuis, op school, bij behandelaars."
  wide={true}
>
  <section class="hero">
    <div class="hero__intro">
      <p class="hero__eyebrow">Werkdocument</p>
      <h1 class="hero__title">Alvah</h1>
      <p class="hero__lede">
        Voor wie met hem werkt: thuis, op De Mheen, in het SWV, bij opa en oma.
      </p>
      <p class="hero__story">
        Hier verzamelen we wat de toetsen laten zien, wat wetenschappelijk onderbouwd is, wat we
        zelf zien werken, en welke vragen open staan. Geen rapport over hem. Een gedeelde kaart
        van hetzelfde terrein, waar iedereen die met hem werkt aan bijdraagt.
      </p>
      <p class="hero__story">
        Begin bij de <a href="/samenvatting">samenvatting</a> als je net aansluit. Voor het
        volledige beeld: het <a href="/dossier">dossier</a>.
      </p>
    </div>
    <figure class="hero__portrait">
      <img
        src="/img/Alvah.jpg"
        alt="Alvah met een van zijn kippen"
        width="1079"
        height="1079"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="quick-facts">
    <dl class="meta-grid">
      <div>
        <dt>Leeftijd</dt>
        <dd>Bijna 8</dd>
      </div>
      <div>
        <dt>School</dt>
        <dd>De Mheen, Apeldoorn</dd>
      </div>
      <div>
        <dt>Stamgroep</dt>
        <dd>Inktvissen (middenbouw)</dd>
      </div>
      <div>
        <dt>Context</dt>
        <dd>PKU · dyslexie-aanvraag · ADHD-achtig</dd>
      </div>
    </dl>
  </section>

  <section>
    <h2 class="section-head"><span class="num">A</span>Hoe het nu staat</h2>
    <div class="chip-row">
      <a class="data-chip" href="/voortgang">
        <div class="data-chip__label">Laatste milestone</div>
        <div class="data-chip__value">
          {laatsteMilestone ? laatsteMilestone.data.titel : 'Nog geen milestones gelogd'}
        </div>
        <div class="data-chip__meta">
          {laatsteMilestone ? formatDatum(laatsteMilestone.data.datum) : 'Tijdlijn start zodra eerste milestone is vastgelegd'}
        </div>
      </a>

      <a class="data-chip" href="/oefeningen">
        <div class="data-chip__label">Actieve interventies</div>
        <div class="data-chip__value">{actieveInterventies}</div>
        <div class="data-chip__meta">met evidence sterk of matig</div>
      </a>

      <a class="data-chip" href="/vragen">
        <div class="data-chip__label">Openstaande vragen</div>
        <div class="data-chip__value">{openVragen}</div>
        <div class="data-chip__meta">status open of in-gesprek</div>
      </a>
    </div>
  </section>

  <section>
    <h2 class="section-head"><span class="num">B</span>Voor Alvah zelf</h2>
    <a class="alvah-spelen-haak" href="/spelen">
      <div class="alvah-spelen-haak__label">Spelen</div>
      <div class="alvah-spelen-haak__titel">Oefenspelletjes</div>
      <p class="alvah-spelen-haak__desc">Vijf korte spellen voor onthouden, zoeken en wisselen. Voor Alvah om zelf te spelen.</p>
      <span class="alvah-spelen-haak__cta">Naar de spelen →</span>
    </a>
  </section>

  <section>
    <h2 class="section-head"><span class="num">C</span>Het volledige dossier</h2>
    <div class="nav-grid">
      {navCards.map((card) => (
        <a class="nav-card" href={card.pad}>
          <div class="nav-card__num">{card.num}</div>
          <div class="nav-card__title">{card.titel}</div>
          <div class="nav-card__desc">{card.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <section>
    <div class="callout">
      <div class="callout__label">Voor wie met Alvah werkt</div>
      <p>
        Deze site is niet openbaar geïndexeerd maar wel deelbaar. Spreek ons aan als iets niet klopt
        of als je iets mist. Dit is een werkdocument, geen vast gegeven.
      </p>
    </div>
  </section>

  <style>
    /* ---------- Hero ---------- */
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
      align-items: center;
      gap: 56px;
      padding-top: var(--section-padding-y);
      padding-bottom: calc(var(--section-padding-y) / 2);
    }
    .hero__eyebrow {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 1.2em;
    }
    .hero__title {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: clamp(2.6rem, 6vw, 4.4rem);
      line-height: 1;
      letter-spacing: -0.02em;
      margin-bottom: 0.4em;
    }
    .hero__lede {
      font-family: var(--font-heading);
      font-weight: 300;
      font-style: italic;
      font-size: clamp(1.15rem, 2vw, 1.4rem);
      line-height: 1.4;
      color: var(--green-deep);
      max-width: 28ch;
      margin-bottom: 1.6em;
    }
    .hero__story {
      color: var(--ink-soft);
      font-size: 1rem;
      line-height: 1.65;
      max-width: 42ch;
      margin-bottom: 1em;
    }
    .hero__story:last-child { margin-bottom: 0; }
    .hero__story a {
      color: var(--green);
      text-decoration-color: var(--green-line);
    }
    .hero__story a:hover { text-decoration-color: var(--green); }

    .hero__portrait {
      margin: 0;
      position: relative;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 4px;
      background: var(--green-soft);
    }
    .hero__portrait img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .hero__portrait::after {
      content: "";
      position: absolute;
      inset: 0;
      box-shadow: inset 0 0 0 1px rgba(20, 20, 20, 0.06);
      pointer-events: none;
      border-radius: inherit;
    }

    @media (max-width: 860px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 32px;
        padding-top: var(--section-padding-y-mobile);
        padding-bottom: calc(var(--section-padding-y-mobile) / 1.5);
      }
      .hero__intro { order: 2; }
      .hero__portrait { order: 1; max-width: 360px; margin: 0 auto; width: 100%; }
    }

    /* ---------- Quick facts band ---------- */
    .quick-facts {
      padding-top: 0;
      padding-bottom: calc(var(--section-padding-y) / 1.5);
    }
    .quick-facts .meta-grid {
      margin: 0;
      padding-top: 1.5em;
    }
    @media (max-width: 720px) {
      .quick-facts { padding-bottom: var(--section-padding-y-mobile); }
    }

    /* ---------- Spelen-haak ---------- */
    .alvah-spelen-haak {
      display: block;
      padding: 24px 28px;
      border-radius: 14px;
      background: var(--green-soft);
      border-left: 4px solid var(--green);
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .alvah-spelen-haak:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    }
    .alvah-spelen-haak__label {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--green);
      font-weight: 500;
      margin-bottom: 6px;
    }
    .alvah-spelen-haak__titel {
      font-family: var(--font-heading);
      font-weight: 500;
      font-size: 1.6rem;
      margin-bottom: 6px;
    }
    .alvah-spelen-haak__desc {
      color: var(--ink-soft);
      max-width: 50ch;
      margin: 0 0 10px;
    }
    .alvah-spelen-haak__cta {
      color: var(--green);
      font-weight: 500;
    }
    @media (prefers-reduced-motion: reduce) {
      .alvah-spelen-haak { transition: none; }
      .alvah-spelen-haak:hover { transform: none; }
    }
  </style>
</BaseLayout>
