    border: 1px solid var(--line);
    margin-bottom: 10px;
    padding: 16px 22px;
    background: var(--paper);
  }
  .indicator[open] {
    background: var(--green-soft);
    border-color: var(--green-line);
  }
  .indicator summary {
    cursor: pointer;
    font-size: 1rem;
  }
  .indicator ul {
