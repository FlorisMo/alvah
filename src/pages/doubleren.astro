    content: counter(item, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 14px;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--green);
  }

